# Docker runtime env for ttlock-local-server
# Copy to .env and adjust if needed.

PORT=8990

# Linux BLE path
TTLOCK_SCANNER_TYPE=bluez-dbus
BLUEZ_ADAPTER=hci0
BLUEZ_SCAN_MODE=le-all
TTLOCK_WEBUI_KEEP_MONITOR=1

# D-Bus connect and GATT timing
TTLOCK_DBUS_CONNECT_TIMEOUT_SECONDS=5
TTLOCK_DBUS_SERVICES_RESOLVED_TIMEOUT_SECONDS=1
TTLOCK_DBUS_DISCOVER_SERVICES_RETRIES=4
TTLOCK_DBUS_DISCOVER_SERVICES_RETRY_DELAY_MS=200
TTLOCK_DBUS_STOP_SCAN_SETTLE_MS=400

# BLE subscribe / command timing
TTLOCK_BLE_POST_CONNECT_DELAY_MS=200
TTLOCK_BLE_SUBSCRIBE_RETRIES=3
TTLOCK_BLE_SUBSCRIBE_RETRY_DELAY_MS=300

# Linux wake window retries
TTLOCK_LINUX_WAKE_WINDOW_MS=15000
TTLOCK_LINUX_WAKE_MAX_ATTEMPTS=8
TTLOCK_LINUX_WAKE_DISCONNECT_COOLDOWN_MS=2000
TTLOCK_LINUX_WAKE_RETRY_DELAY_MS=1200
TTLOCK_LINUX_WAKE_REDISCOVERY_TIMEOUT_MS=1800
